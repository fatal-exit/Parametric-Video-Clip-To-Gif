# Python caches and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environment files
.env
.env.*

# Editors and OS files
.vscode/
.idea/
Thumbs.db
.DS_Store

# Local media folders
media/input/*
!media/input/.gitkeep
media/output/*
!media/output/.gitkeep
